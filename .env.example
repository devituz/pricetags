# Copy to .env and adjust. docker compose reads this file automatically,
# `make run` loads it via godotenv. Never commit the real .env.

# Host ports
APP_PORT=8080
POSTGRES_PORT=5433
ES_PORT=9200

# Postgres
POSTGRES_DB=pricetags
POSTGRES_USER=pricetags
POSTGRES_PASSWORD=pricetags

# Elasticsearch
ES_JAVA_OPTS=-Xms512m -Xmx512m

# App (used by `make run` outside docker)
HTTP_ADDR=:8080
DATABASE_URL=postgres://pricetags:pricetags@localhost:5433/pricetags?sslmode=disable
ELASTICSEARCH_URL=http://localhost:9200
MIGRATE_ON_START=true
